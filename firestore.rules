rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Cache auth.uid() using SELECT pattern for performance optimization (up to 94% faster)
    function currentUserId() {
      return (select auth.uid());
    }

    function isAuthenticated() {
      return auth != null;
    }

    // Check if user is the owner of the tenant
    function isTenantOwner(tenantId) {
      return isAuthenticated() && currentUserId() == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
    }

    // --- Domain Validators ---
    
    function isValidTenant(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerEmail is string &&
             data.agentStatus in ['online', 'offline'];
    }

    function isValidConversation(data) {
      return data.tenantId is string &&
             data.customerPhone is string &&
             data.status in ['active', 'completed', 'escalated'] &&
             data.windowExpiresAt is string; // ISO 8601
    }

    function isValidQuota(data) {
      return data.tenantId is string &&
             data.date is string &&
             data.sentCount is int &&
             data.limit is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tenants/{tenantId} {
      // Only the owner can read/write their tenant config
      allow read, update: if isAuthenticated() && currentUserId() == resource.data.ownerId;
      allow create: if isAuthenticated() && isValidTenant(request.resource.data) && request.resource.data.ownerId == currentUserId();
      
      match /conversations/{convId} {
        allow read, write: if isTenantOwner(tenantId) && isValidConversation(request.resource.data);
      }

      match /metrics/{metricId} {
        allow read: if isTenantOwner(tenantId);
      }

      match /webhooks/{webhookId} {
        allow read: if isTenantOwner(tenantId);
      }

      match /quotas/{quotaId} {
        allow read: if isTenantOwner(tenantId);
      }

      match /audit_logs/{logId} {
        allow read: if isTenantOwner(tenantId);
        allow create: if isTenantOwner(tenantId); // Workers/System create these
      }
    }
  }
}
